# Copy this file to config.env and edit values before running scripts.

# Cloud DERP server.
DERP_HOST=117.72.114.86
DERP_REGION_ID=900
DERP_REGION_CODE=jdc
DERP_REGION_NAME=JDCloud
DERP_LATITUDE=39.9042
DERP_LONGITUDE=116.4074

# SSH target for the cloud server.
VPS_SSH=root@117.72.114.86

# Tailscale peer used for verification. This is the lab server in this setup.
LAB_TAILSCALE_IP=100.88.219.12
LAB_SSH=100.88.219.12

# derper version. Keep this close to your Tailscale client version.
DERPER_VERSION=v1.98.5

# Local paths used by scripts.
LOCAL_CERT_PATH=certs/jdc-derper-117.72.114.86.crt
